# 0xRecipe repo-root environment example.
# Copy this file to `.env` at the repo root and fill in the secret values.
# Do not commit `.env`.

# --- Chain: Injective EVM testnet ---
RPC_URL=https://1439.rpc.thirdweb.com
CHAIN_ID=1439
USDC_ADDRESS=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d

# Current deployment recorded in contracts/deployments/injective-testnet-1439.json.
AGENT_ESCROW_ADDRESS=0xdfc4a81cf2e3008b86939003ac984a0660aa4af6
FUSION_SPLITTER_ADDRESS=0x21e44c98ae0a275fc4215c57bd66668386ed29d2

# Public payout / demo addresses from the current deployment.
PLATFORM_ADDR=0xB48a902817E9f9a15c5bad33751033Ad30F000A3
HARDCODED_CREATOR_ADDR=0x31EF222895Ac2cb5553EE93A510738d67D73B9B1

# Backend signer. Use MNEMONIC for the demo scripts:
#   address index 0 = backend charge/deposit relayer
#   address index 1 = agent used by e2e / legal-reviewer-agent
#   address index 2 = creator if generated by configure-env
#   address index 3 = platform if generated by configure-env
# The backend signer must match the deployed AgentEscrow.onlyBackend address:
# 0xF615D233EDff07f48ce7a23863Ccd819051bccff
MNEMONIC=

# Alternative to MNEMONIC for backend runtime only. Leave blank when using MNEMONIC.
BACKEND_PRIVATE_KEY=

# --- Model gateway: OpenAI-compatible ---
LLM_GATEWAY_URL=
LLM_GATEWAY_KEY=
LLM_GATEWAY_KEY_PURE=

# Optional gateway tuning.
LLM_GATEWAY_TIMEOUT_MS=45000

# --- Mock mode (local demo fallback) ---
# MOCK_CHAIN=1 avoids RPC writes/private-key requirements. It returns a fixed
# mock escrow balance and synthetic tx hashes while still exercising voucher,
# nonce, SSE, and ledger logic.
MOCK_CHAIN=0
MOCK_AGENT_BALANCE_USDC=10.00

# MOCK_FUSION=1 avoids LLM gateway calls and returns a deterministic fixture.
MOCK_FUSION=0

# --- Recipe store / pricing ---
# Leave blank to use data/0xrecipe.db. If that DB already exists, changing
# RECIPE_PRICE_USDC does not update the stored recipe; use recipe-admin instead.
DATABASE_PATH=
RECIPE_PRICE_USDC=1.00
VOUCHER_DOMAIN=0xRecipe

# --- API / CORS ---
# Leave blank to allow any browser origin for the demo. For deployed web, set:
# CORS_ORIGINS=https://your-web.example
CORS_ORIGINS=
PORT=3001

# --- Web public runtime config ---
NEXT_PUBLIC_API_BASE=http://localhost:3001
NEXT_PUBLIC_EVENTS_URL=http://localhost:3001/events/stream

# Agent address shown in the dashboard and used for balance reads.
# For the standard MNEMONIC-based demo this should be address index 1.
NEXT_PUBLIC_DEMO_AGENT=

# --- Agent / e2e scripts ---
E2E_PORT=3011
AGENT_PORT=3021
# Optional: point legal-reviewer-agent.ts at an already-running backend.
AGENT_API_BASE=
