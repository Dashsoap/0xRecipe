# 0xRecipe backend environment.
# Copy to ../.env (repo root, gitignored) and fill in real values.
# NEVER commit real keys. All values below are blank or neutral placeholders.

# --- Chain (Injective EVM testnet) ---
RPC_URL=https://k8s.testnet.json-rpc.injective.network/
CHAIN_ID=1439
USDC_ADDRESS=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d
AGENT_ESCROW_ADDRESS=
FUSION_SPLITTER_ADDRESS=
PLATFORM_ADDR=
HARDCODED_CREATOR_ADDR=

# Backend hot wallet: funded with gas; relays deposits and signs charge().
BACKEND_PRIVATE_KEY=

# --- Model gateway (OpenAI-compatible) ---
# A single OpenAI-compatible base_url. Use a neutral placeholder here.
LLM_GATEWAY_URL=https://your-openai-compatible-gateway/v1
# Standard source key.
LLM_GATEWAY_KEY=
# Official source key.
LLM_GATEWAY_KEY_PURE=

# --- Recipe store (SQLite) ---
# Where the recipes database lives. Default: ${repoRoot}/data/0xrecipe.db
# (the dir is created on boot). Recipes — incl. price — are read from here on
# every request; the server and the admin CLI must point at the same path.
DATABASE_PATH=

# --- Pricing / voucher ---
# Per-call price in USDC (decimal string, e.g. 0.05). This now only SEEDS a
# fresh database. The runtime price lives in the recipes table and is changed
# without a restart via: node backend/scripts/recipe-admin.mjs set-price <id> <usdc>
RECIPE_PRICE_USDC=
# EIP-712 domain name for the per-call payment voucher.
VOUCHER_DOMAIN=

# --- Web / CORS ---
# Comma-separated browser origins allowed to read the API cross-origin (the web
# dashboard's SSE + balance reads). Leave empty to allow any origin (safe: these
# endpoints serve only public on-chain data; the paid call is voucher-authorized).
# Example for production: https://your-web-app.example,https://www.your-web-app.example
CORS_ORIGINS=
