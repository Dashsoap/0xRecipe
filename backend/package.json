{
  "name": "@0xrecipe/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "0xRecipe backend — Fusion engine + prepaid escrow billing on Injective EVM.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "doctor": "node --env-file=../.env scripts/doctor.mjs",
    "e2e:dry-run": "node --env-file=../.env --import tsx scripts/e2e-dry-run.ts",
    "gateway:smoke": "node --env-file=../.env scripts/gateway-smoke.mjs",
    "recipe:reset-demo": "node --env-file=../.env scripts/recipe-admin.mjs reset-demo"
  },
  "dependencies": {
    "@0xrecipe/shared": "workspace:*",
    "@0xrecipe/x402": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.6.0",
    "openai": "^4.67.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
